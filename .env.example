JWT_ACCESS_SECRET=change-me-access-secret-at-least-32-chars
JWT_REFRESH_SECRET=change-me-refresh-secret-at-least-32-chars
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=2592000
JSON_STORE_PATH=./data/badminton.json

# --- Persistence (Vercel KV / Upstash Redis) ---
# When both are set, the app uses Redis instead of the JSON file store.
# Auto-injected by the Vercel Upstash integration in production.
KV_REST_API_URL=
KV_REST_API_TOKEN=

# --- Feature 04 (Facebook Bot Crawler) ---
FACEBOOK_COOKIES_PATH=./secrets/fb-cookies.json
FACEBOOK_GROUP_URLS=https://www.facebook.com/groups/<id1>/,https://www.facebook.com/groups/<id2>/

# --- Feature 05 (AI Post Parser) ---
GEMINI_API_KEY=your-gemini-api-key
